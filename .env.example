# ─── Admin access ──────────────────────────────────────────────
# Set these on Vercel: Project → Settings → Environment Variables.
# This is the single secure admin login. Only this email + password
# (plus the built-in demo accounts) can sign in. The password is
# verified server-side and NEVER ships to the browser.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_NAME=Administrator

# ─── Session signing ───────────────────────────────────────────
# Secret used to sign the session cookie so it can't be forged.
# REQUIRED in production. Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string
